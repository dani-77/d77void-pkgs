# Template file for 'mullvadvpn'
pkgname=mullvadvpn
version=2026.3
revision=1
archs="x86_64* aarch64*"
hostmakedepends="tar xz"
short_desc="Mullvad VPN client"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="custom:mullvadvpn"
homepage="https://mullvad.net/"
distfiles="https://github.com/mullvad/mullvadvpn-app/releases/download/${version}-beta2/MullvadVPN-${version}-beta2_amd64.deb"
checksum=b213a49199808efc9b5b25ec1b0fe18d7decf2f39b5873de3c149c81e6f16fc8
repository=d77

do_extract() {
	ar x ${XBPS_SRCDISTDIR}/${pkgname}-${version}/MullvadVPN-${version}-beta2_amd64.deb
	tar xf data.tar.xz -C ${wrksrc}
	mv ${wrksrc}/opt/Mullvad\ VPN ${wrksrc}/opt/Mullvad\VPN
}

do_install() {
	vmkdir /usr/bin
	vmkdir /usr/lib/systemd/system
	vmkdir /usr/share/bash-completion/completions
	vmkdir /usr/share/fish/vendor_completions.d
	vmkdir /usr/share/icons/hicolor
	vmkdir /usr/share/applications
	vmkdir /usr/share/doc/mullvad-vpn
	vmkdir /usr/share/zsh/site-functions

	vsv mullvad

	vcopy usr/bin/* /usr/bin/
	vcopy usr/lib/systemd/system/* /usr/lib/systemd/system/
	vcopy usr/share/icons/hicolor/* /usr/share/icons/hicolor/
	vcopy usr/share/applications/* /usr/share/applications/
	vcopy usr/share/doc/mullvad-vpn/* /usr/share/doc/mullvad-vpn/
	vcopy usr/share/bash-completion/completions/* /usr/share/bash-completion/completions/
	vcopy usr/share/fish/vendor_completions.d/* /usr/share/fish/vendor_completions.d/

	vmkdir /usr/share/zsh/site-functions

	mkdir -p ${DESTDIR}/opt/Mullvad\ VPN
	cp -a ${wrksrc}/opt/MullvadVPN/* ${DESTDIR}/opt/Mullvad\ VPN/

	# Exclude apisocks5 completely
	rm -f ${DESTDIR}/opt/Mullvad\ VPN/resources/apisocks5
}

pkg_install() {
	vmove usr/local/share/zsh/site-functions/*
	vlicense LICENSE
}
