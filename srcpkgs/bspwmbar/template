# Template file for 'bspwmbar'
pkgname=bspwmbar
version=0.6.2
revision=1
archs="x86_64"
build_style=gnu-configure
hostmakedepends="git gettext pkg-config"
makedepends="alsa-lib-devel libxcb-devel xcb-util-devel xcb-util-wm-devel xcb-util-image-devel xcb-util-renderutil-devel freetype-devel cairo-devel harfbuzz-devel fontconfig-devel"
depends="bspwm sxhkd nerd-fonts-symbols-ttf"
short_desc="A lightweight status bar for bspwm"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="ISC"
homepage="https://github.com/odknt/bspwmbar"
distfiles="https://github.com/odknt/${pkgname}/archive/v${version}.tar.gz"
checksum=ac5414238c4f195f761c33a7ba87b1a13d4b72fb3f5b7f6a513cf83112345c6f
repository=d77

do_build() {
	cp ${FILESDIR}/config.def.h ./
	./configure
	make
}

do_install() {
	make PREFIX=/usr DESTDIR=${DESTDIR} install
	vlicense LICENSE
}
