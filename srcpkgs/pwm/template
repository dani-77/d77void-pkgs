# Template file for 'pwm'
pkgname=pwm
version=0.2.2
revision=3
archs="x86_64 x86_64-musl"
build_style=cargo
hostmakedepends="pkg-config libXft-devel libX11-devel"
depends="dmenu libX11 libXft st wireless_tools"
short_desc="PipaWindowManager, a Penrose Lib Tiling Window Manager"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="MIT"
homepage="https://github.com/dani-77/pwm"
changelog="https://github.com/dani-77/${pkgname}/archive/refs/tags/${version}"
distfiles="https://github.com/dani-77/${pkgname}/archive/refs/tags/${version}.tar.gz"
checksum=af535715c76e0adc3b7a902e4d3ed3755cdbedc37fa870217622c6f9b851840b
repository=d77

do_build() {
	cargo build --release
}

do_install() {
	sed -i '3i conky -c ~/.conkyrc1 &' etc/xdg/pwm/startup.sh
	vbin target/release/pwm
	vinstall pwm.desktop 644 usr/share/xsessions/
	vmkdir /etc/xdg/pwm
	vcopy etc/xdg/pwm/'*' /etc/xdg/pwm/
	vlicense LICENSE
}
