# Template file for 'oxwm'
pkgname=oxwm
version=0.9.0
revision=3
archs="x86_64 x86_64-musl"
build_style=cargo
hostmakedepends="make libX11-devel libXft-devel freetype-devel fontconfig-devel pkg-config"
depends="libX11 libXft freetype fontconfig"
short_desc="Dynamic window manager written in Rust"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="GPL-3.0-or-later"
homepage="https://ox-docs.vercel.app/"
distfiles="https://github.com/tonybanters/${pkgname}/archive/refs/tags/v${version}.tar.gz"
checksum=bc92d0bc56ece22a7393bb32ab5ecad92a90d75b8d6e7a86250bf608b436d6f3
repository=d77

if [ "$XBPS_TARGET_LIBC" = "musl" ]; then
	repository=musld77
fi

pre_install() {
	metapackage=yes
	cp ${FILESDIR}/battery.rs src/bar/blocks/
}

post_install() {
	vinstall ${FILESDIR}/oxwm.desktop 755 usr/share/xsessions/
}
