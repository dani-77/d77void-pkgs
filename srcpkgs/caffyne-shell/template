# Template file for 'caffyne-shell'
pkgname=caffyne-shell
version=1.0.0.b8a2433
revision=1
hostmakedepends="python3-devel python3-pip cmake git pkg-config"
makedepends="gtk+3-devel cairo-devel libgirepository-devel libdbusmenu-glib-devel libbluetooth-devel python3-cairo-devel libglib-devel"
depends="awww matugen cinnamon-desktop playerctl fabric-cli gnome-bluetooth bluez brightnessctl NetworkManager python3-loguru python3-click"
short_desc="New, lightweight, desktop shell for linux, powered by Fabric"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="GPL-3.0-or-later"
homepage="https://caffyne.org/"
_commit="b8a2433"
distfiles="https://github.com/caffyne-org/caffyne-shell/archive/${_commit}.tar.gz"
checksum=ca672e03022fd6f2081230cff50b6d5b104b78022c59301bb247ab185cc76580
python_version=3
repository=d77

do_install() {
	vsed -i '3i python3 -m venv ~/.config/caffyne-shell/venv' start.sh
	python -m venv venv
	source venv/bin/activate
	pip install --upgrade pip
	pip install pycairo
	pip install -r requirements.txt
	cd snippets/blur/lib
	make && cd ../../../
	cd snippets/hacktk/lib
	make && cd ../../../
	vmkdir etc/xdg/caffyne-shell
	vcopy '*' etc/xdg/caffyne-shell/
}
