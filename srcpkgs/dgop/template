# Template file for 'dgop'
pkgname=dgop
version=0.2.2
revision=1
archs="x86_64"
build_style=gnu-makefile
build_helper="qemu"
makedepends="go"
short_desc="API & CLI for System & Process Monitoring"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="MIT"
homepage="https://github.com/AvengeMedia/dgop"
changelog="https://github.com/AvengeMedia/dgop/releases/tag/v${version}"
distfiles="https://github.com/AvengeMedia/${pkgname}/archive/refs/tags/v${version}.tar.gz"
checksum=2e45d94d2227bb596844681e66f948aeea4a09be3f7ee88dcbbf38938cabec32
repository=d77

do_install() {
	vbin bin/dgop
	vbin bin/dgop dankgop
	vlicense LICENSE
	vdoc README.md
}
post_install() {
	for sh in bash fish zsh; do
	vtargetrun bin/dgop completion "$sh" > "dankgop.$sh"
	vcompletion "dankgop.$sh" "$sh" dankgop
	done
}
