# Template file for 'wmd77'
pkgname=wmd77
version=0.4.0
revision=4
archs="x86_64"
build_style=cargo
hostmakedepends="pkg-config libXft-devel libX11-devel"
depends="dmenu libX11 libXft st"
short_desc="Penrose Lib Tiling Window Manager"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="MIT"
homepage="https://github.com/dani-77/wmd77"
changelog="https://github.com/dani-77/${pkgname}/archive/refs/tags/${version}"
distfiles="https://github.com/dani-77/${pkgname}/archive/refs/tags/${version}.tar.gz"
checksum=d40837b8c97735eae1c4d63ee850ee1e44b06c4765beb765d06573e6d2ea0c23
repository=d77

do_build() {
	cargo build --release
}

do_install() {
	sed -i '3i conky -c ~/.conkyrc1 &' etc/xdg/wmd77/startup.sh
	vbin target/release/wmd77
	vinstall wmd77.desktop 644 usr/share/xsessions/
	vmkdir /etc/xdg/wmd77
	vcopy etc/xdg/wmd77/'*' /etc/xdg/wmd77/
	vlicense LICENSE
}
