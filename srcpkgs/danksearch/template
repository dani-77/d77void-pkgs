# Template file for 'danksearch'
pkgname=danksearch
version=0.3.2
revision=3
archs="x86_64 x86_64-musl"
build_style=gnu-makefile
build_helper="qemu"
hostmakedepends="go"
short_desc="Fast, configurable filesystem search with fuzzy matching"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="MIT"
homepage="https://danklinux.com"
distfiles="https://github.com/AvengeMedia/${pkgname}/archive/refs/tags/v${version}.tar.gz"
checksum=9454a2935c149ca3eb64106d59c266f513daff90438bac8b58e3a66b477521a9
repository=d77

do_install() {
	vsv dsearch
	vbin bin/dsearch
	vlicense LICENSE
	vdoc README.md
}

post_install() {
	for sh in bash fish zsh; do
	vtargetrun bin/dsearch completion "$sh" > "dsearch.$sh"
	vcompletion "dsearch.$sh" "$sh" dsearch
	done
}
