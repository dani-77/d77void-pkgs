# Template file for 'danksearch'
pkgname=danksearch
version=0.3.1
revision=1
build_style=gnu-makefile
build_helper="qemu"
hostmakedepends="go"
short_desc="Fast, configurable filesystem search with fuzzy matching"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="GPL-3.0-or-later"
homepage="https://danklinux.com"
distfiles="https://github.com/AvengeMedia/${pkgname}/archive/refs/tags/v${version}.tar.gz"
checksum=d6e34db26bb3a48eae6fb86164bd6745f4539e9ba62064a99adf6a58038253a1
repository=d77

do_install() {
	vmkdir /etc/sv/dsearch
	echo '#!/bin/sh' > ${DESTDIR}/etc/sv/dsearch/run
	echo 'exec 2>&1' >> ${DESTDIR}/etc/sv/dsearch/run
	echo 'sv check dbus > /dev/null || exit 1' >> ${DESTDIR}/etc/sv/dsearch/run
	echo 'exec /usr/bin/dsearch serve' >> ${DESTDIR}/etc/sv/dsearch/run
	chmod 755 ${DESTDIR}/etc/sv/dsearch/run

	vbin bin/dsearch

	vlicense LICENSE
	vdoc README.md
}

post_install() {
	for sh in bash fish zsh; do
	vtargetrun bin/dsearch completion "$sh" > "dsearch.$sh"
	vcompletion "dsearch.$sh" "$sh" dsearch
	done
}
