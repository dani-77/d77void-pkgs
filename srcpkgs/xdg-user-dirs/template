repository=d77

# Upstream's meson.build sets LOCALEDIR to the raw `localedir` option
# instead of joining it with `prefix` (meson.build:57), so it never
# resolves to /usr/share/locale like every other package expects.
# This left translated directory names (Desktop, Downloads, etc.)
# permanently in English regardless of locale. Force the correct path.
pre_configure() {
	sed -i "s|get_option('localedir')|'/usr/share/locale'|" meson.build
}
