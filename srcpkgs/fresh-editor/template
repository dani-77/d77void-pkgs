# Template file for 'fresh-editor'
pkgname=fresh-editor
version=0.4.1
revision=1
build_style=cargo
hostmakedepends="pkg-config"
makedepends="libgcc-devel glibc-devel oniguruma-devel"
short_desc="Terminal text editor you can just use"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="GPL-2.0-only"
homepage="https://sinelaw.github.io/fresh/"
changelog="https://github.com/sinelaw/fresh/releases/tag/v${version}"
distfiles="https://github.com/sinelaw/fresh/archive/refs/tags/v${version}.tar.gz"
checksum=a61a98a2057729ead79183f39357f8bb034cbd3f919342d4395247aa79a4025c
repository=d77

do_install() {
	vbin target/x86_64-unknown-linux-gnu/release/fresh
	vinstall ${FILESDIR}/fresh-editor.desktop 644 usr/share/applications/
	vmkdir usr/share/doc/fresh-editor
	vcopy docs/'*' usr/share/doc/fresh-editor/
}
