# Template file for 'fresh-editor'
pkgname=fresh-editor
version=0.4.3
revision=1
build_style=cargo
hostmakedepends="pkg-config"
makedepends="libgcc-devel glibc-devel oniguruma-devel"
short_desc="Terminal text editor you can just use"
maintainer="Daniel Azevedo <daniazevedo77@posteo.net>"
license="GPL-2.0-only"
homepage="https://sinelaw.github.io/fresh/"
changelog="https://github.com/sinelaw/fresh/releases/tag/v${version}"
distfiles="https://github.com/sinelaw/fresh/archive/refs/tags/v${version}.tar.gz"
checksum=1f417ab81c2af9f44aff53a4e7ca31053b4a93b572fb82bf49b0c30c804c6dcf
repository=d77

do_install() {
	vbin target/x86_64-unknown-linux-gnu/release/fresh
	vmkdir usr/libexec/${pkgname}
	vcopy crates/fresh-editor/plugins usr/libexec/${pkgname}/
	vcopy crates/fresh-editor/keymaps usr/libexec/${pkgname}/
	vinstall crates/fresh-editor/resources/fresh.desktop 644 usr/share/applications

	for icon in crates/fresh-gui/resources/icon_*x*.png; do
		size=${icon##*icon_}
		size=${size%.png}
		vinstall "$icon" 644 "usr/share/icons/hicolor/${size}/apps" fresh.png
	done

	vman crates/fresh-editor/resources/fresh.1
	vdoc README.md
}
